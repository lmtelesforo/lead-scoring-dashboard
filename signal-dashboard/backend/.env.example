# ============================================================
# Signal Dashboard — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub
# ============================================================

# Groq API (free at console.groq.com)
GROQ_API_KEY=gsk_your_groq_key_here

# Supabase (free at supabase.com → New Project → Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: Frontend URL for CORS (set to your Vercel/Netlify URL in production)
FRONTEND_URL=http://localhost:5173
